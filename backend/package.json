{
  "name": "legacy-ai-vault-backend",
  "version": "1.0.0",
  "description": "Legacy AI Vault - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "echo 'SQL manuell im Supabase Dashboard ausführen'",
    "db:push": "npx drizzle-kit push --force && npx tsx src/db/enable-rls.ts",
    "db:rls": "npx tsx src/db/enable-rls.ts"
  },
  "dependencies": {
    "@elevenlabs/client": "^0.15.1",
    "@supabase/supabase-js": "^2.39.0",
    "@types/jsonwebtoken": "^9.0.10",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.4",
    "puppeteer": "^24.39.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "drizzle-kit": "^0.31.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
