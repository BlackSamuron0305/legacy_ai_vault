# ============================================================
# LegacyAI Vault — Environment Variables
# Copy this file to .env and fill in your values.
# This single .env at root is shared by backend, ai_service,
# and docker-compose via env_file.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_PASSWORD=vault_secret
DATABASE_URL=postgresql://vault:vault_secret@localhost:5432/legacy_ai_vault

# ---------- Authentication ----------
JWT_SECRET=change-me-to-a-random-64-char-string

# ---------- HuggingFace ----------
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ---------- ElevenLabs ----------
ELEVENLABS_API_KEY=xi_xxxxxxxxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxx

# ---------- Service URLs (used by backend to reach AI service) ----------
AI_SERVICE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ---------- Storage ----------
UPLOADS_DIR=./uploads

# ---------- Optional ----------
MAKE_WEBHOOK_URL=
LOG_LEVEL=info
PORT=3001
